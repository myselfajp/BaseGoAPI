# ---------------------------------------------------------------------------
# Project configuration
# ---------------------------------------------------------------------------
PROJECT_NAME=Base Go API
API_V1_PREFIX=/v1
SERVER_PORT=8000

# ---------------------------------------------------------------------------
# JWT configuration
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------------------------------------------------------------------------
# Database configuration
# DATABASE_URL is optional; if empty it is built from the components below.
# ---------------------------------------------------------------------------
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/base_go_api?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=base_go_api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_SSLMODE=disable

# ---------------------------------------------------------------------------
# Admin bootstrap
# ---------------------------------------------------------------------------
CREATE_ADMIN_ON_STARTUP=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMeAdmin123

# ---------------------------------------------------------------------------
# CORS ("*" or a comma-separated list of origins)
# ---------------------------------------------------------------------------
CORS_ORIGINS=*

# Requests per minute per IP on auth endpoints (<= 0 disables rate limiting)
AUTH_RATE_LIMIT_PER_MINUTE=5

# ---------------------------------------------------------------------------
# Email provider ("aws_ses" or "smtp")
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=smtp
SENDER_EMAIL=noreply@example.com

# AWS SES (required if EMAIL_PROVIDER=aws_ses)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=eu-central-1

# SMTP (required if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ---------------------------------------------------------------------------
# OTP / two-factor authentication
# ---------------------------------------------------------------------------
OTP_LENGTH=6
OTP_EXPIRATION_MINUTES=10
FORCE_TWO_FACTOR_AUTH=false

# ---------------------------------------------------------------------------
# Email verification
# ---------------------------------------------------------------------------
EMAIL_VERIFICATION_TOKEN_EXPIRATION_MINUTES=60
REQUIRE_EMAIL_VERIFICATION=true

# ---------------------------------------------------------------------------
# Password reset
# ---------------------------------------------------------------------------
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=60

# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------
BASE_URL=http://localhost:8000
